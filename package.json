{
  "name": "codex-switcher",
  "private": true,
  "version": "1.1.0",
  "license": "MIT",
  "description": "Cross-platform desktop manager for Codex CLI accounts",
  "type": "module",
  "keywords": [
    "codex",
    "openai",
    "account-manager",
    "auth-json",
    "browser-dashboard",
    "rust",
    "react",
    "typescript"
  ],
  "scripts": {
    "dev": "node scripts/pnpm-run.mjs exec tauri dev",
    "dev:ui": "vite --host 127.0.0.1 --port 1420",
    "dev:web": "node scripts/pnpm-run.mjs build && node scripts/run-lan.mjs",
    "build": "tsc && vite build",
    "tauri:build": "node scripts/tauri-build.mjs",
    "build:windows": "node scripts/build-windows.mjs",
    "test": "node scripts/pnpm-run.mjs build && cargo test --manifest-path src-tauri/Cargo.toml",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "preview": "vite preview",
    "version:bump": "node scripts/bump-version.mjs",
    "version:patch": "node scripts/bump-version.mjs patch",
    "version:minor": "node scripts/bump-version.mjs minor",
    "version:major": "node scripts/bump-version.mjs major"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^9.0.0",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-dialog": "2.6.0",
    "@tauri-apps/plugin-opener": "2.5.3",
    "@tauri-apps/plugin-process": "2.3.1",
    "@tauri-apps/plugin-updater": "2.10.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/cli": "2.10.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "rcedit": "^5.0.2",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
